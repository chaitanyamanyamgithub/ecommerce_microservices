    {
      "title": "Total RPS (All Services)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(ecommerce_http_server_duration_milliseconds_count[1m])) or sum(rate(ecommerce_http_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "transparent": true
    },
    {
      "title": "Global Error Rate (5xx)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(ecommerce_http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[1m])) / sum(rate(ecommerce_http_server_duration_milliseconds_count[1m])) * 100",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "percent"
        }
      },
      "transparent": true
    },
    {
      "title": "Infrastructure / Pods Running",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(up)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      }
    },
    {
      "title": "Service Golden Signals",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "transparent": true
    },
    {
      "title": "Traffic by Service (RPS)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exported_job) (rate(ecommerce_http_server_duration_milliseconds_count[1m])) > 0",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "transparent": true,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 40,
            "gradientMode": "hue",
            "lineWidth": 3
          }
        }
      }
    },
    {
      "title": "P95 Latency by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, exported_job) (rate(ecommerce_http_server_duration_milliseconds_bucket[1m])))",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 40,
            "gradientMode": "hue",
            "lineWidth": 3
          }
        }
      },
      "transparent": true
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exported_job) (rate(ecommerce_http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[1m])) / sum by (exported_job) (rate(ecommerce_http_server_duration_milliseconds_count[1m]))",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 40,
            "gradientMode": "hue",
            "lineWidth": 3
          }
        }
      },
      "transparent": true
    },
    {
      "title": "Recent Application Errors (Loki)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"docker\"} |~ \"(?i)error|exception|fail\""
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "transparent": true
    }
  ],
