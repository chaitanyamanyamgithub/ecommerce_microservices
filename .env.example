# ===========================================================
# eCommerce Microservices — Environment Variables
# ===========================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ===========================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGEME_use_a_strong_password_here
MONGO_AUTH_SOURCE=admin

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGEME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ── Payment Gateway (Stripe / Razorpay) ─────────────────────
PAYMENT_GATEWAY_KEY=pk_test_your_test_key
PAYMENT_GATEWAY_SECRET=sk_test_your_secret_key

# ── Grafana ──────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGEME_grafana_password

# ── General ──────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
